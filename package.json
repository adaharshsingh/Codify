{
  "name": "codify",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"npm --prefix client run dev\"",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "node-html-parser": "^7.1.0",
    "uuid": "^9.0.1"
  }
}
